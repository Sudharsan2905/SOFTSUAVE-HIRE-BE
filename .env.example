# ── Required ────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=softsuavehire

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-64-char-hex-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=360
REFRESH_TOKEN_EXPIRE_DAYS=1

# ── CORS ─────────────────────────────────────────────────────────────────────
# JSON array of allowed origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Google OAuth (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OpenAI (optional — required for AI question generation) ─────────────────
OPENAI_API_KEY=

# ── Email / SMTP (optional — required for sending invite emails) ─────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── App behaviour ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_REACCESS_COUNT=3
